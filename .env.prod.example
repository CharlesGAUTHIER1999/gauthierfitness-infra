# ════════════════════════════════════════════════════════════════════
#  GauthierFitness — Production environment variables
#  Copy this file to .env on the production OVH server
#  ⚠  Never commit this file with real values
#  ⚠  In production: use strong, unique secrets
# ════════════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────────
APP_NAME="GauthierFitness"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://gauthierfitness.fr
FRONTEND_URL=https://gauthierfitness.fr

# ─── Database ─────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=gauthier_fitness
DB_USERNAME=gauthier_prod
DB_PASSWORD=STRONG_PRODUCTION_PASSWORD_64_CHARS
DB_ROOT_PASSWORD=STRONG_PRODUCTION_ROOT_PASSWORD

# ─── Redis ────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ─── Mail ─────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=gauthierfitness.help@gmail.com
MAIL_PASSWORD=MOT_DE_PASSE_APPLICATION_GMAIL
MAIL_ENCRYPTION=tls
MAIL_FROM_NAME="Gauthier Fitness"
MAIL_FROM_ADDRESS=noreply@gauthierfitness.fr
MAIL_SUPPORT_ADDRESS=gauthierfitness.help@gmail.com

# ─── Stripe (mode LIVE pour production) ──────────────────────────
STRIPE_SECRET=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_secret_key_here
STRIPE_PUBLIC_KEY=your_stripe_secret_key_here

# ─── Docker / GHCR ────────────────────────────────────────────────
IMAGE_TAG=latest
GITHUB_REPOSITORY=your-username/gauthierfitness

# ─── Frontend (injected at Docker build time) ─────────────────────
VITE_API_URL=https://gauthierfitness.fr/api
VITE_STRIPE_PUBLIC_KEY=your_stripe_secret_key_here

# ─── Misc ─────────────────────────────────────────────────────────
FILESYSTEM_DISK=public
APP_LOCALE=fr
LOG_CHANNEL=stderr
LOG_LEVEL=warning

# ─── Security ─────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=gauthierfitness.fr
SESSION_DOMAIN=.gauthierfitness.fr
SESSION_SECURE_COOKIE=true
CORS_ALLOWED_ORIGINS=https://gauthierfitness.fr,https://www.gauthierfitness.fr

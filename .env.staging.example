# ════════════════════════════════════════════════════════════════════
#  GauthierFitness — Variables d'environnement Staging
#  Copier ce fichier en .env sur le serveur OVH staging
#  ⚠  Ne jamais committer ce fichier avec de vraies valeurs
# ════════════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────────
APP_NAME="GauthierFitness Staging"
APP_ENV=staging
APP_KEY=base64:GENERER_AVEC_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://staging.gauthierfitness.fr
FRONTEND_URL=https://staging.gauthierfitness.fr

# ─── Base de données ──────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=gauthier_fitness_staging
DB_USERNAME=gauthier_staging
DB_PASSWORD=CHANGER_CE_MOT_DE_PASSE_STAGING
DB_ROOT_PASSWORD=CHANGER_ROOT_STAGING

# ─── Redis ────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# ─── Mail ─────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=gauthierfitness.help@gmail.com
MAIL_PASSWORD=MOT_DE_PASSE_APPLICATION_GMAIL
MAIL_ENCRYPTION=tls
MAIL_FROM_NAME="Gauthier Fitness"
MAIL_FROM_ADDRESS=noreply@gauthierfitness.fr
MAIL_SUPPORT_ADDRESS=gauthierfitness.help@gmail.com

# ─── Stripe (mode TEST pour staging) ─────────────────────────────
STRIPE_SECRET=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PUBLIC_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Docker / GHCR ────────────────────────────────────────────────
IMAGE_TAG=develop
GITHUB_REPOSITORY=ton-username/gauthierfitness

# ─── Frontend (injecté au build Docker) ───────────────────────────
VITE_API_URL=https://staging.gauthierfitness.fr/api
VITE_STRIPE_PUBLIC_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Sécurité ─────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=staging.gauthierfitness.fr
SESSION_DOMAIN=.gauthierfitness.fr
SESSION_SECURE_COOKIE=true
CORS_ALLOWED_ORIGINS=https://staging.gauthierfitness.fr

# ─── Divers ───────────────────────────────────────────────────────
FILESYSTEM_DISK=public
APP_LOCALE=fr
LOG_CHANNEL=stderr
LOG_LEVEL=debug

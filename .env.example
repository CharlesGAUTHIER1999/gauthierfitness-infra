# Variables requises par le docker-compose.yml de base (stack en isolation locale).
# Pour staging/prod, voir .env.staging.example / .env.prod.example (domaines, HTTPS, etc.)

# Tag d'image à pull depuis GHCR (ex: latest, develop, ou un sha court)
IMAGE_TAG=latest

# Base de données MySQL
DB_DATABASE=gauthierfitness
DB_USERNAME=gauthierfitness
DB_PASSWORD=
DB_ROOT_PASSWORD=
